# OpenRouter — used for candidate generation (Stage 1).
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Anthropic — used for Sonnet primary labeling + Opus dry-run (Stage 3).
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI — used for the GPT cross-check labeler (Stage 3 crosscheck phase).
OPENAI_API_KEY=your_openai_api_key_here

# Together AI — used for the DeepSeek cross-check labeler (Stage 3 crosscheck phase).
TOGETHER_API_KEY=your_together_api_key_here

# Hugging Face — used to pull base Gemma and to publish the trained model.
HF_TOKEN=your_huggingface_token_here
