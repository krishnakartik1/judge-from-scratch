# Secrets
.env
.env.*
!.env.example

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.eggs/
build/
dist/

# Virtual environments
.venv/
venv/
env/

# uv
.uv/

# Pipeline outputs and intermediate artifacts
outputs/
data/raw/*.jsonl
data/pairs/*.jsonl
data/labeled/*.jsonl
data/formatted/*.jsonl

# Locked v1 raw artifacts (tracked despite the broad ignore above).
# These cost real API spend / pin reproducibility, so they live in git.
!data/raw/bbq_sample.jsonl
!data/raw/candidates.jsonl
!data/raw/candidates_enriched.jsonl
!data/pairs/pairs.jsonl

# Stage 3a eval-set holdout artifacts. The eval set will carry hand-labeled
# gold verdicts (Stage 3b) and must be tracked. The .meta.json sidecar is
# tracked by default since the broad ignore above only matches .jsonl.
!data/pairs/eval_set_unlabeled.jsonl
!data/pairs/pairs_to_label.jsonl
!data/pairs/pairs_unused_religion.jsonl

# Stage 4 (Claude labeling) artifacts. The labeled training data and
# audit trail (dryrun records, dropped pairs, cost ledger) are tracked
# despite the broad data/labeled/*.jsonl ignore above. Provider-specific
# in-flight state (.parse_errors.jsonl, crosscheck_results.jsonl) stays
# ignored — those are transient sidecars, not durable artifacts.
!data/labeled/labeled_pairs.jsonl
!data/labeled/dropped_pairs.jsonl
!data/labeled/dryrun_sonnet.jsonl
!data/labeled/dryrun_opus.jsonl
!data/labeled/dryrun_sonnet_v1.jsonl
!data/labeled/dryrun_opus_v1.jsonl
!data/labeled/.cost_ledger.jsonl

# Stage 5 (formatting) artifacts. Final SFT/DPO datasets, the synthesis
# audit trail, and cost ledger are tracked. Batch-API in-flight state
# (.batches.json), parse-error / batch-error sidecars, and terminal-
# error list stay ignored — transient sidecars only useful mid-run.
!data/formatted/sft.jsonl
!data/formatted/dpo.jsonl
!data/formatted/synthesis_results.jsonl
!data/formatted/.synth_cost_ledger.jsonl
data/formatted/.batches.json
data/formatted/.synth_parse_errors.jsonl
data/formatted/.synth_batch_errors.jsonl
data/formatted/.synth_errors.jsonl
# Local backup of the v1 dryrun (120-token target) before we re-tuned the
# synth prompt. Kept on disk for reference; not durable enough to track.
data/formatted/_dryrun_v1_*/

# Local prepatch backups for ad-hoc rollback. Never tracked.
data/pairs/_prepatch/

# Label-tool transient sidecars (timestamped backup + exclusive lock).
data/pairs/*.bak-*
data/pairs/*.lock

# Model checkpoints and adapters
*.safetensors
*.bin
*.gguf
*.ckpt
*.pt
*.pth
checkpoints/
train/checkpoints/
adapters/
merged/

# Stage 6 cost ledger — gitignored by default; un-ignore explicitly if
# you want spend history committed (Stages 4 and 5 do; Stage 6 doesn't
# yet because GPU-cost ledger is per-developer, not per-project).
train/.cost_ledger.jsonl

# Modal CLI cache + Wandb local run logs (Stage 6 will create these)
.modal/
wandb/

# Caches
.cache/
.huggingface/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Editor / OS
.vscode/
.idea/
.DS_Store

# Claude Code local state
.claude/scheduled_tasks.lock
